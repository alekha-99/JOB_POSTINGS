# Database (PostgreSQL)
# Get your connection string from https://neon.tech or run local PostgreSQL
DATABASE_URL="postgresql://user:password@localhost:5432/jobdb?schema=public"

# Scraping Configuration
SCRAPE_INTERVAL_CRON="*/30 * * * *"
MAX_CONCURRENT_SCRAPERS=5
REQUEST_DELAY_MS=2000
MAX_RETRY_ATTEMPTS=3

# Filtering Options
DAYS_LOOKBACK=1
USA_ONLY=true
IT_JOBS_ONLY=true

# Browser (Playwright) Settings
HEADLESS=true
BROWSER_TIMEOUT_MS=30000

# Logging Configuration
LOG_LEVEL=info
LOG_DIR=./logs

# Application Settings
NODE_ENV=development
PORT=3000
